# ── Base de données (PostgreSQL) ──────────────────────────────
# Local
DATABASE_URL=postgresql://postgres:password@localhost:5432/mon_compagnon
# Render (remplacer par l'URL fournie par Render)
# DATABASE_URL=postgresql://user:pass@host/dbname

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=remplacez-par-une-cle-aleatoire-longue-minimum-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Application ───────────────────────────────────────────────
APP_NAME=Mon Compagnon API
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=*

# ── Cloudinary (stockage images) ─────────────────────────────
# Créer un compte gratuit sur https://cloudinary.com
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ── Bail — délai alerte expiration (jours) ────────────────────
BAIL_ALERTE_JOURS=30

# ── Serveur ───────────────────────────────────────────────────
PORT=8000
